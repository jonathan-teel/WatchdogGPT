LOG_FILE_PATH=/path/to/your/access.log
OPENAI_API_KEY=your_api_key
OPENAI_API_MODEL=gpt-5-mini
OPENAI_BASE_URL=
BUFFER_FLUSH_INTERVAL=15
BUFFER_SIZE_LIMIT=500
CHUNK_SIZE=200
MAX_WORKERS=2
MAX_API_CALLS_PER_PERIOD=60
API_RATE_LIMIT_PERIOD=60
REQUEST_TIMEOUT_SECONDS=30
MAX_OUTPUT_TOKENS=900
MAX_RETRIES=3
INITIAL_RETRY_BACKOFF_SECONDS=1
OPENAI_REASONING_EFFORT=low
PROMPT_CACHE_KEY=watchdoggpt-analysis-v2
ALERT_WEBHOOK_URL=
